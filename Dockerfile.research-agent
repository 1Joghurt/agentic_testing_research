ARG PYTHON_VERSION=3.14.6
ARG UV_VERSION=0.11.21
ARG NODE_VERSION=26.3.1

ARG NPM_VERSION=11.17.0
ARG PLAYWRIGHT_VERSION=1.61.0
ARG PLAYWRIGHT_MCP_VERSION=0.0.76

FROM ghcr.io/astral-sh/uv:${UV_VERSION} AS uv
FROM node:${NODE_VERSION}-bookworm-slim AS node
FROM python:${PYTHON_VERSION}-slim-bookworm

ENV PATH="/app/.venv/bin:/usr/local/bin:${PATH}" \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

COPY --from=uv /uv /uvx /bin/
COPY --from=node /usr/local/ /usr/local/

RUN apt-get update \
    && apt-get install --yes --no-install-recommends libatomic1 xauth \
    && npm install --global --no-audit --no-fund \
        "npm@${NPM_VERSION}" \
        "playwright@${PLAYWRIGHT_VERSION}" \
        "playwright-chromium@${PLAYWRIGHT_VERSION}" \
        "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" \
    && playwright install --with-deps chromium \
    && ln -s "$(node -e 'process.stdout.write(require("/usr/local/lib/node_modules/playwright").chromium.executablePath())')" \
        /usr/local/bin/playwright-chromium \
    && npm cache clean --force \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./

RUN uv sync --frozen --no-dev --no-install-project --no-cache

COPY agent_runner ./agent_runner

RUN uv sync --frozen --no-dev --no-cache \
    && chmod -R a+rX /app

ENTRYPOINT ["/app/.venv/bin/python", "-m", "agent_runner.main"]
